# ──────────────────────────────────────────────
# RunPod Serverless Endpoint Configuration
# ──────────────────────────────────────────────

# RunPod API key (from https://www.runpod.io/console/user/settings)
RUNPOD_API_KEY=

# Endpoint ID (assigned when you create the serverless endpoint)
RUNPOD_ENDPOINT_ID=

# ──────────────────────────────────────────────
# ks-backend .env.dev values (copy these once deployed)
# ──────────────────────────────────────────────

# VLM_ENDPOINT=https://api.runpod.ai/v2/${RUNPOD_ENDPOINT_ID}/openai/v1/chat/completions
# VLM_MODEL=granite-docling-258M
# VLM_API_KEY=${RUNPOD_API_KEY}
